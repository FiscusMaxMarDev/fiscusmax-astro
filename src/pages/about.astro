  background: #211057;
  padding: 80px 24px 96px;
  text-align: center;
}
.about-creds-inner {
  max-width: 960px;
  margin: 0 auto;
}
.creds-subtext {
  font-family: 'Funnel Display', sans-serif;
  font-size: 18px;
  font-weight: 300;
  color: rgba(248, 244, 229, 0.75);
  max-width: 600px;
  margin: 0 auto 56px;
  line-height: 1.7;
}
.creds-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  text-align: left;
}
.cred-card {
