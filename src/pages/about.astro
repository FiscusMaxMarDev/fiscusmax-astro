  line-height: 1.8;
}
.team-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 48px 32px;
  margin-bottom: 64px;
}
.team-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.team-photo {
  width: 220px;
  height: 220px;
  border-radius: 50%;
  object-fit: cover;
  object-position: center top;
  border: 3px solid #d6b12f;
  display: block;
}
.team-name {
  font-family: 'DM Serif Display', serif;
  font-size: 20px;
  font-weight: 400;
  margin: 0;
}
.team-title {
  font-family: 'Funnel Display', sans-serif;
  font-size: 14px;
  font-weight: 300;
  color: rgba(248, 244, 229, 0.75);
  margin: 0;
  text-align: center;
}
.team-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}
.team-stat-num {
  font-family: 'DM Serif Display', serif;
  font-size: 64px;
  font-weight: 400;
  line-height: 1;
  margin: 0;
}
.team-stat-label {
  font-family: 'Funnel Display', sans-serif;
  font-size: 14px;
  font-weight: 400;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(248, 244, 229, 0.65);
  margin: 0;
}

/* ==========================================================
   SECTION 7 — GROWTH STORY
========================================================== */
.about-growth {
  background: #211057;
  padding: 96px 24px;
  text-align: center;
}
.about-growth-inner {
  max-width: 780px;
  margin: 0 auto;
}
.about-growth .about-prose-cream {
  text-align: left;
}

/* ==========================================================
   SECTION 8 — CREDENTIALS
========================================================== */
