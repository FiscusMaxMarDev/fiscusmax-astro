  padding: 140px 24px 100px;
  text-align: center;
}
.about-hero-inner {
  max-width: 800px;
  margin: 0 auto;
}
.about-hero-h1 {
  font-family: 'DM Serif Display', serif;
  font-size: 45px;
  font-weight: 400;
  line-height: 1.15;
  margin-bottom: 28px;
}
.about-hero-sub {
  font-family: 'Funnel Display', sans-serif;
  font-size: 20px;
  font-weight: 300;
  color: rgba(248, 244, 229, 0.85);
  max-width: 680px;
  margin: 0 auto;
  line-height: 1.7;
}

/* ==========================================================
   SECTION 2 — JADAH STORY
========================================================== */
.about-story {
  background: #f8f4e5;
  padding: 96px 24px;
  text-align: center;
}
.about-story-inner {
  max-width: 780px;
  margin: 0 auto;
}
.story-pullquote {
  position: relative;
  text-align: left;
  padding: 16px 0 0;
}
.story-quote-mark {
