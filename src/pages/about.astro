  line-height: 1;
  opacity: 0.3;
  display: block;
  margin-bottom: -24px;
}
.story-body p {
  font-family: 'Funnel Display', sans-serif;
  font-size: 18px;
  font-weight: 300;
  color: #114b1c;
  line-height: 1.9;
  margin-bottom: 20px;
}
.story-body p:last-child { margin-bottom: 0; }
.story-divider {
  border-top: 1px solid rgba(214, 177, 47, 0.3);
  margin-top: 56px;
}

/* ==========================================================
   SECTION 3 — BRAND STORY
========================================================== */
.about-brand {
  background: #f8f4e5;
  padding: 80px 24px 96px;
  text-align: center;
}
.about-brand-inner {
  max-width: 800px;
  margin: 0 auto;
  text-align: center;
}
.about-brand-inner .about-prose {
  text-align: left;
}

/* ==========================================================
   SECTION 4 — MISSION & VISION
========================================================== */
.about-mission {
  background: #211057;
  padding: 80px 24px;
  text-align: center;
}
.about-mission-inner {
  max-width: 800px;
  margin: 0 auto;
}
.mission-pullquote {
  position: relative;
  margin-bottom: 32px;
}
.mission-quote-mark {
  font-family: 'DM Serif Display', serif;
  font-size: 80px;
  line-height: 1;
  opacity: 0.3;
  display: block;
  margin-bottom: -16px;
}
.mission-quote-text {
  font-family: 'DM Serif Display', serif;
  font-size: 26px;
  font-weight: 400;
  line-height: 1.4;
  max-width: 680px;
  margin: 0 auto;
}
.mission-divider {
  border-top: 1px solid rgba(214, 177, 47, 0.35);
  max-width: 680px;
  margin: 32px auto 48px;
}
.about-mission .about-prose-cream {
  text-align: left;
}

/* ==========================================================
   SECTION 5 — WHAT MAKES US DIFFERENT
========================================================== */
.about-diff {
  background: #f8f4e5;
  padding: 96px 24px;
  text-align: center;
}
.about-diff-inner {
  max-width: 960px;
  margin: 0 auto;
}
.diff-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
  margin-top: 16px;
  text-align: left;
}
.diff-card {
  background: #f8f4e5;
  border: 1.5px solid #114b1c;
  border-radius: 16px;
  padding: 36px;
  transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
}
.diff-card:hover {
  border-color: #d6b12f;
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(214, 177, 47, 0.2);
}
.diff-card-title {
  font-family: 'Funnel Display', sans-serif;
  font-size: 20px;
  font-weight: 400;
  color: #114b1c;
  margin-bottom: 14px;
}
.diff-card-body {
  font-family: 'Funnel Display', sans-serif;
  font-size: 16px;
  font-weight: 300;
  color: rgba(17, 75, 28, 0.8);
  line-height: 1.75;
}

/* ==========================================================
