}
.cred-rule {
  border-top: 1px solid rgba(214, 177, 47, 0.3);
  margin-bottom: 20px;
}
.cred-title {
  font-family: 'Funnel Display', sans-serif;
  font-size: 18px;
  font-weight: 400;
