---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout>

  <!-- ============================================================
       HERO
  ============================================================ -->
  <section id="hero">
    <div class="hero-inner">

      <!-- Left column -->
      <div class="hero-left">

        <div class="hero-pill">
          <span class="pill-dot"></span>
          Free Consultations Available
        </div>

        <h1 class="hero-headline">Your Family Deserves Every&nbsp;Dollar&nbsp;Back.</h1>

        <p class="hero-sub">Tax preparation and resolution made simple, affordable, and stress-free — because hardworking families shouldn't leave money on&nbsp;the&nbsp;table.</p>

        <div class="hero-ctas">
          <CTAButton href="#book" label="Book a Free Consultation" variant="primary" />
          <CTAButton href="#services" label="See How We Help" variant="secondary" />
        </div>

        <div class="hero-divider"></div>

        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-num">$2M+</span>
            <span class="stat-label">Saved for Families</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">500+</span>
            <span class="stat-label">Cases Resolved</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">98%</span>
            <span class="stat-label">Client Satisfaction</span>
          </div>
        </div>

      </div><!-- /hero-left -->

      <!-- Right column — animated cards -->
      <div class="hero-right">

        <!-- Floating badge -->
        <div class="case-badge">&#x2713; IRS Case Closed &#x2713;</div>

        <!-- Card 1: IRS Notice -->
        <div class="card-wrap card-wrap-1" id="heroCard1">
          <div class="hero-card card-irs">
            <div class="card-alert-label">IRS Notice Received</div>
            <div class="card-title">Balance Due: $12,450</div>
            <div class="card-body">Action Required — Response deadline in 30 days</div>
          </div>
        </div>

        <!-- Card 2: Resolution -->
        <div class="card-wrap card-wrap-2" id="heroCard2">
          <div class="hero-card card-res">
            <div class="card-icon-box">
              <span class="card-dollar">$</span>
            </div>
            <div class="card-success-label">Fiscus Max Resolved It</div>
            <div class="card-title">Negotiated reduction secured:</div>
            <div class="card-savings">$8,200 saved</div>
          </div>
        </div>

      </div><!-- /hero-right -->

    </div><!-- /hero-inner -->
  </section>


  <!-- ============================================================
       PAIN POINTS
  ============================================================ -->
  <section id="painpoints">
    <div class="section-inner">

      <div class="painpoints-header reveal">
        <div class="section-tag">Does This Sound Like You?</div>
      </div>

      <div class="painpoints-grid" id="painGrid">

        <!-- Card 1 -->
        <div class="pain-card">
          <div class="pain-card-top">
            <h3 class="pain-card-headline">You Dread April Every Year</h3>
            <div class="bullet-cards">
              <div class="bullet-card"><p>You worked hard all year and still owe</p></div>
              <div class="bullet-card"><p>Your refund was smaller than you expected</p></div>
              <div class="bullet-card"><p>Nobody explained why or what to do differently</p></div>
              <div class="bullet-card"><p>You just sign whatever they put in front of you</p></div>
            </div>
          </div>
          <div>
            <a href="#book" class="btn-tier3">Book a Free Consultation</a>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="pain-card">
          <div class="pain-card-top">
            <h3 class="pain-card-headline">There's a Letter You Haven't Opened Yet</h3>
            <div class="bullet-cards">
              <div class="bullet-card"><p>The IRS sent a notice and it's been sitting there</p></div>
              <div class="bullet-card"><p>You're not sure if ignoring it made things worse</p></div>
              <div class="bullet-card"><p>You feel embarrassed but don't know who to call</p></div>
              <div class="bullet-card"><p>You tried to handle it and got more confused</p></div>
            </div>
          </div>
          <div>
            <a href="#services" class="btn-tier3">See How We Can Help</a>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="pain-card">
          <div class="pain-card-top">
            <h3 class="pain-card-headline">You're Not Sure You're Doing It Right</h3>
            <div class="bullet-cards">
              <div class="bullet-card"><p>You have a side hustle but don't know what to claim</p></div>
              <div class="bullet-card"><p>You switched jobs or had a major life change</p></div>
              <div class="bullet-card"><p>You're using software and hoping for the best</p></div>
              <div class="bullet-card"><p>Nobody has ever actually walked you through your return</p></div>
            </div>
          </div>
          <div>
            <a href="#services" class="btn-tier3">Learn More</a>
          </div>
        </div>

        <!-- Card 4 -->
        <div class="pain-card">
          <div class="pain-card-top">
            <h3 class="pain-card-headline">Your Business Deserves Better Than Box Software</h3>
            <div class="bullet-cards">
              <div class="bullet-card"><p>You're self-employed and the taxes feel impossible</p></div>
              <div class="bullet-card"><p>You don't know how much to set aside quarterly</p></div>
              <div class="bullet-card"><p>You're probably missing deductions every single year</p></div>
              <div class="bullet-card"><p>Your accountant doesn't really understand your business</p></div>
            </div>
          </div>
          <div>
            <a href="#book" class="btn-tier3">Book a Business Consultation</a>
          </div>
        </div>

      </div>

    </div>
  </section>


  <!-- ============================================================
       SERVICES
  ============================================================ -->
  <section id="services">
    <div class="services-inner" id="servicesInner">

      <!-- Header -->
      <div class="services-header">
        <div class="section-tag">What We Do</div>
        <h2 class="section-title">
          <span class="grad-gold">We're In Your Corner</span>
        </h2>
      </div>

      <!-- Tab Nav -->
      <div class="services-tabs" role="tablist">
        <button class="tab-btn active" role="tab" aria-selected="true"  aria-controls="panel-0">
          <span class="tab-full">Tax Preparation</span><span class="tab-short">Preparation</span>
        </button>
        <button class="tab-btn"        role="tab" aria-selected="false" aria-controls="panel-1">
          <span class="tab-full">Tax Resolution</span><span class="tab-short">Resolution</span>
        </button>
        <button class="tab-btn"        role="tab" aria-selected="false" aria-controls="panel-2">
          <span class="tab-full">Tax Planning</span><span class="tab-short">Planning</span>
        </button>
        <button class="tab-btn"        role="tab" aria-selected="false" aria-controls="panel-3">
          <span class="tab-full">Business &amp; Contractors</span><span class="tab-short">Business</span>
        </button>
      </div>

      <!-- Panel 1: Tax Preparation -->
      <div class="tab-panel active" id="panel-0" role="tabpanel">
        <div class="panel-left">
          <h3 class="panel-title">Filing Made Easy</h3>
          <p class="panel-desc">We handle your return from start to finish, finding every credit and deduction your family qualifies for. You just bring your documents, we do the rest.</p>
          <a href="https://forms.monday.com/forms/755fc9f7b7fef79ebac688141a00bf74?r=use1"
             target="_blank" rel="noopener noreferrer" class="panel-cta">Book a Filing Consultation</a>
        </div>
        <div class="panel-right">
          <p class="panel-list-label">What's Included</p>
          <ul class="panel-bullets">
            <li>Federal and state tax return filing</li>
            <li>Credits review (EITC, Child Tax Credit, education)</li>
            <li>Deduction maximization</li>
            <li>Prior year return review</li>
            <li>48-hour quote turnaround</li>
            <li>100% remote, no office visit needed</li>
          </ul>
        </div>
      </div>

      <!-- Panel 2: Tax Resolution -->
      <div class="tab-panel" id="panel-1" role="tabpanel">
        <div class="panel-left">
          <h3 class="panel-title">IRS Problems? We've Got You.</h3>
          <p class="panel-desc">You didn't mean for it to get this far. Life happened, and suddenly the IRS feels like an enemy. We've helped hundreds of families in exactly your position reduce what they owe, stop the notices, and finally breathe again. We know the system because we work inside it every day.</p>
          <a href="https://forms.monday.com/forms/755fc9f7b7fef79ebac688141a00bf74?r=use1"
             target="_blank" rel="noopener noreferrer" class="panel-cta">Get IRS Help Now</a>
        </div>
        <div class="panel-right">
          <p class="panel-list-label">How We Resolve It</p>
          <ul class="panel-bullets">
            <li>Offer in Compromise (reduce total balance)</li>
            <li>IRS Installment Agreements</li>
            <li>Penalty &amp; interest abatement</li>
            <li>Currently Not Collectible status</li>
            <li>Unfiled return compliance</li>
            <li>Wage garnishment &amp; levy release</li>
          </ul>
        </div>
      </div>

      <!-- Panel 3: Tax Planning -->
      <div class="tab-panel" id="panel-2" role="tabpanel">
        <div class="panel-left">
          <h3 class="panel-title">Stay Ahead All Year</h3>
          <p class="panel-desc">Don't wait until April. We help you build a year-round strategy so tax season never catches your family off guard again. Smart planning today means more in your pocket tomorrow.</p>
          <a href="https://forms.monday.com/forms/755fc9f7b7fef79ebac688141a00bf74?r=use1"
             target="_blank" rel="noopener noreferrer" class="panel-cta">Start Your Tax Plan</a>
        </div>
        <div class="panel-right">
          <p class="panel-list-label">What Planning Includes</p>
          <ul class="panel-bullets">
            <li>Quarterly tax review check-ins</li>
            <li>Withholding optimization</li>
            <li>Life event tax impact analysis</li>
            <li>Retirement contribution strategy</li>
            <li>Deduction planning calendar</li>
            <li>Annual tax projection report</li>
          </ul>
        </div>
      </div>

      <!-- Panel 4: Business & Contractors -->
      <div class="tab-panel" id="panel-3" role="tabpanel">
        <div class="panel-left">
          <h3 class="panel-title">Built for Business Too</h3>
          <p class="panel-desc">From freelancers to LLCs, we help independent contractors and business owners maximize deductions, stay compliant, and keep more of what they earn. Self-employed taxes don't have to be complicated.</p>
          <a href="https://forms.monday.com/forms/755fc9f7b7fef79ebac688141a00bf74?r=use1"
             target="_blank" rel="noopener noreferrer" class="panel-cta">Book a Business Consultation</a>
        </div>
        <div class="panel-right">
          <p class="panel-list-label">Business Services</p>
          <ul class="panel-bullets">
            <li>Self-employment tax preparation</li>
            <li>Quarterly estimated tax filing</li>
            <li>Business deduction maximization</li>
            <li>LLC and S-Corp tax strategy</li>
            <li>Contractor vs employee classification</li>
            <li>Multi-state filing support</li>
          </ul>
        </div>
      </div>

    </div>
  </section>


  <!-- ============================================================
       QUOTE BANNER
  ============================================================ -->
  <section id="quote-banner">
    <div class="quote-inner" id="quoteBannerInner">
      <span class="quote-mark">&ldquo;</span>
      <p class="quote-text">You Work Hard. Your Tax Situation Shouldn't Work Against You.</p>
      <hr class="quote-rule-bottom">
      <p class="quote-attribution">&mdash; FISCUS MAX TAX ADVOCATES</p>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ============================================================
       GOLD COIN INTERACTIVE
  ============================================================ -->
  <section id="coin">
    <div class="section-inner">
      <div class="coin-layout">

        <!-- Left: copy + stats -->
        <div class="coin-text reveal">
          <div class="section-tag">The Tax Gap</div>
          <h2 class="section-title">
            <span class="grad-dark">Millions of Families Leave Money Behind Every Year</span>
          </h2>
          <p class="section-body">The IRS estimates that working families miss out on thousands of dollars in refunds and credits annually — not because they're dishonest, but because no one ever showed them how to claim what they've earned.</p>

          <div class="coin-facts">

            <div class="coin-fact">
              <div class="fact-icon"></div>
              <div class="fact-content">
                <strong>$1,200 in Average Missed Deductions</strong>
                <span>Most families never claim work expenses, education credits, or childcare deductions they fully qualify for.</span>
              </div>
            </div>

            <div class="coin-fact">
              <div class="fact-icon"></div>
              <div class="fact-content">
                <strong>14 Million IRS Notices Sent Annually</strong>
                <span>Most can be resolved quickly with the right representation — but ignored notices escalate into liens and levies.</span>
              </div>
            </div>

            <div class="coin-fact">
              <div class="fact-icon"></div>
              <div class="fact-content">
                <strong>Average Settlement: 40&cent; on the Dollar</strong>
                <span>With professional negotiation, most tax debts can be settled for significantly less than what's originally owed.</span>
              </div>
            </div>

          </div>
        </div><!-- /coin-text -->

        <!-- Right: 3D coin + canvas chart -->
        <div class="coin-visual reveal reveal-d1">

          <p class="coin-hint" id="coinHint">Hover to flip</p>

          <div class="coin-scene" id="coinScene" role="button" aria-label="Flip coin to reveal statistic" tabindex="0">
            <div class="coin-3d" id="coin3d">

              <div class="coin-face coin-front">
                <img
                  src="/assets/images/coin%20tree%20logo.png"
                  alt="Fiscus Max"
                  class="coin-tree-logo"
                />
                <div class="coin-label-front">Fiscus Max</div>
              </div>

              <div class="coin-face coin-back">
                <div class="coin-stat-num">60%</div>
                <div class="coin-stat-label">Average IRS Debt Reduction</div>
              </div>

            </div>
          </div>

          <!-- Canvas chart — revealed after first flip -->
          <div class="chart-wrap" id="chartWrap">
            <div class="chart-title">Where Families Lose Money</div>
            <canvas id="pieChart" width="240" height="240" aria-label="Pie chart showing how families lose money"></canvas>
            <div class="chart-legend" id="chartLegend"></div>
          </div>

          <!-- Tooltip element positioned by JS -->
          <div id="chartTooltip"></div>

        </div><!-- /coin-visual -->

      </div>
    </div>
  </section>


  <!-- ============================================================
       ABOUT US
  ============================================================ -->
  <section id="about">
    <div class="section-inner">
      <div class="about-layout">

        <!-- Left: copy -->
        <div class="about-text reveal">
          <div class="section-tag">Our Story</div>
          <h2 class="section-title">
            <span class="grad-dark">We Built This Firm for Families Like Yours</span>
          </h2>

          <p class="about-body">We've sat across from families who were embarrassed, scared, and convinced their situation was beyond repair. It never was. At Fiscus Max, we believe every working family deserves the same quality tax help that Fortune 500 companies get. We were founded by tax professionals who grew up in working-class households — we know exactly what it feels like to open that IRS letter.</p>

          <p class="about-body">We built this firm because we saw too many families left alone to navigate a complicated, unforgiving tax system. Losing money they'd rightfully earned. Facing penalties they didn't know how to fight. That changes the moment you call us.</p>

          <div class="about-values">
            <div class="value-row">
              <div class="value-check"></div>
              <span>We fight for every dollar you're owed</span>
            </div>
            <div class="value-row">
              <div class="value-check"></div>
              <span>We explain everything in plain language</span>
            </div>
            <div class="value-row">
              <div class="value-check"></div>
              <span>We're by your side from start to finish</span>
            </div>
            <div class="value-row">
              <div class="value-check"></div>
              <span>Your consultation is always free</span>
            </div>
          </div>

          <a href="#book" class="about-cta">Book a Free Consultation</a>
        </div><!-- /about-text -->

        <!-- Right: team headshots -->
        <div class="about-photo reveal reveal-d1">
          <div class="about-stat">
            <span class="about-stat-number">500+</span>
            <div class="about-stat-label">Families Served</div>
          </div>
          <div class="team-grid">
            <div class="team-card reveal reveal-d1">
              <img src="/assets/images/keelyng_headshot_darkwood(1).png" alt="Keelyn Givens" class="team-headshot" />
              <div class="team-name">Keelyn Givens</div>
              <div class="team-title">CEO / Co-Founder</div>
            </div>
            <div class="team-card reveal reveal-d2">
              <img src="/assets/images/ChelseaL_Headshot.png" alt="Chelsea Leggett" class="team-headshot" />
              <div class="team-name">Chelsea Leggett</div>
              <div class="team-title">People &amp; Insurance Director / Co-Founder</div>
            </div>
            <div class="team-card reveal reveal-d3">
              <img src="/assets/images/grantwallace_headshot.png" alt="Grant Wallace" class="team-headshot" />
              <div class="team-name">Grant Wallace</div>
              <div class="team-title">Brand Operations Director</div>
            </div>
            <div class="team-card reveal reveal-d4">
              <img src="/assets/images/EbonyC_Generatedheadshot(1)_3-27-26.png" alt="Ebony Caffey" class="team-headshot" />
              <div class="team-name">Ebony Caffey</div>
              <div class="team-title">Fiscus Max Certified Tax Preparer</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       CAREERS
  ============================================================ -->
  <section id="careers">
    <div class="section-inner">

      <div class="careers-header">
        <div class="section-tag">Join Our Team</div>
        <h2 class="section-title reveal">
          <span class="grad-dark">Grow With a Mission-Driven Team</span>
        </h2>
        <p class="careers-vision reveal reveal-d1">Our vision is to be the trusted financial partner that guides clients from their first refund to their first home, first investment, and first family trust, proving that financial freedom is within reach when someone cares enough to teach.</p>
        <p class="careers-vision reveal reveal-d2">Our Tax Partners and Administrative team make this possible every day, working fully remotely to serve families across the country. Fiscus Max intentionally limits the number of preparers hired per region, ensuring every client receives focused, high-quality attention.</p>
      </div>

      <div class="careers-grid">

        <div class="career-card reveal reveal-d1">
          <span class="job-badge">Remote &middot; Commission-Based</span>
          <h3 class="job-title">Tax Partner</h3>
          <p class="job-desc">Prepare and file individual and family tax returns. Build lasting client relationships and help families maximize their refunds and resolve tax issues.</p>
          <button class="job-cta" onclick="openJobModal('tax-partner')">View Full Description</button>
        </div>

        <div class="career-card reveal reveal-d2">
          <span class="job-badge">Remote &middot; Part-Time</span>
          <h3 class="job-title">Administrative Assistant</h3>
          <p class="job-desc">Support the Fiscus Max team with client onboarding, scheduling, communications, and document management. Be the welcoming first point of contact for our clients.</p>
          <button class="job-cta" onclick="openJobModal('admin-assistant')">View Full Description</button>
        </div>

      </div>

    </div>
  </section>


  <!-- ============================================================
       CREDENTIALS
  ============================================================ -->
  <section id="credentials">
    <div class="section-inner">

      <div class="credentials-header reveal">
        <div class="section-tag">Our Credentials</div>
        <h2 class="section-title">
          <span class="grad-gold">Qualified, Authorized &amp; Accountable</span>
        </h2>
        <p class="credentials-sub">When you trust someone with your taxes and your family's financial future, credentials matter. Here's what we bring to the table.</p>
      </div>

      <div class="credentials-grid" id="credentialsGrid">

        <div class="cred-card">
          <hr class="cred-rule">
          <h3 class="cred-title">IRS Authorized Preparers</h3>
          <p class="cred-body">Every tax professional at Fiscus Max holds an active PTIN (Preparer Tax Identification Number) issued directly by the IRS. This means we are federally recognized and legally authorized to prepare and file your return.</p>
        </div>

        <div class="cred-card">
          <hr class="cred-rule">
          <h3 class="cred-title">Tax Resolution Specialists</h3>
          <p class="cred-body">Our resolution team is trained to negotiate directly with the IRS on your behalf, including Offers in Compromise, Installment Agreements, Penalty Abatements, and Currently Not Collectible status.</p>
        </div>

        <div class="cred-card">
          <hr class="cred-rule">
          <h3 class="cred-title">Your Information Is Safe</h3>
          <p class="cred-body">We take client privacy seriously. All documents are handled through secure, encrypted channels. We never share your information and comply fully with IRS data security standards.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       SOCIAL PROOF BAR
  ============================================================ -->
  <section id="stats-bar">
    <div class="stats-bar-inner">
      <div class="stat-block">
        <div class="stat-num" data-target="2" data-prefix="$" data-suffix="M+">$0M+</div>
        <span class="stat-lbl">Saved for Families</span>
      </div>
      <div class="stat-block">
        <div class="stat-num" data-target="500" data-suffix="+">0+</div>
        <span class="stat-lbl">Cases Resolved</span>
      </div>
      <div class="stat-block">
        <div class="stat-num" data-target="98" data-suffix="%">0%</div>
        <span class="stat-lbl">Client Satisfaction</span>
      </div>
      <div class="stat-block">
        <div class="stat-num" data-target="5" data-suffix=" ★">0 ★</div>
        <span class="stat-lbl">Average Rating</span>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ============================================================
       TESTIMONIALS
  ============================================================ -->
  <section id="testimonials">
    <div class="section-inner">

      <div class="testimonials-header reveal">
        <div class="section-tag">Client Stories</div>
        <h2 class="section-title">
          <span class="grad-gold">Real Results for Real Families</span>
        </h2>
      </div>

      <div class="testimonials-grid">

        <div class="t-card reveal reveal-d1">
          <div class="reviewer-avatar">K</div>
          <div class="testimonial-card-content">
            <div>
              <span class="t-name">Kejuan King</span>
              <span class="t-badge">&#9733;&#9733;&#9733;&#9733;&#9733; Google Review</span>
              <span class="t-time">3 months ago</span>
            </div>
            <p class="t-quote">"Keelyn was my preparer. They were very professional and transparent about the process and I walked away more knowledgeable and with the most money possible for my family. I have gone back each year with great results."</p>
          </div>
        </div>

        <div class="t-card reveal reveal-d2">
          <div class="reviewer-avatar">A</div>
          <div class="testimonial-card-content">
            <div>
              <span class="t-name">Arnesia R</span>
              <span class="t-badge">Local Guide &middot; &#9733;&#9733;&#9733;&#9733;&#9733; Google Review</span>
              <span class="t-time">3 months ago</span>
            </div>
            <p class="t-quote">"I worked with Fiscus Max, LLC for my tax preparation, and the experience was both professional and reassuring. From the first consultation, their team made the process feel less intimidating by explaining complex tax terms in plain, easy-to-understand language. What stood out most was their attention to detail — they actively looked for deductions and credits I might have missed. This not only saved me money but also gave me confidence that my return was accurate and compliant. Overall, Fiscus Max combines expertise, transparency, and a client-first approach."</p>
          </div>
        </div>

        <div class="review-cta-center">
          <a href="https://share.google/AoKRWxzAbIfupgznW"
             target="_blank"
             rel="noopener noreferrer"
             class="btn-leave-review">
            &#9733; Leave Us a Review
          </a>
          <p class="review-cta-sub">Your review helps families find the help they need</p>
        </div>

        <div class="t-card reveal reveal-d3">
          <div class="reviewer-avatar">L</div>
          <div class="testimonial-card-content">
            <div>
              <span class="t-name">Lorin Johnson</span>
              <span class="t-badge">Local Guide &middot; &#9733;&#9733;&#9733;&#9733;&#9733; Google Review</span>
              <span class="t-time">3 months ago</span>
            </div>
            <p class="t-quote">"They are professional and knowledgeable with a great turnaround time."</p>
          </div>
        </div>

        <div class="t-card reveal reveal-d4">
          <div class="reviewer-avatar">T</div>
          <div class="testimonial-card-content">
            <div>
              <span class="t-name">Tammie Givens</span>
