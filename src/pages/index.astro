<script>
  // ============================================================
  // SCROLL REVEAL — fade-in-up for all .reveal elements
  // ============================================================
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

  // ============================================================
  // HERO CARDS — spring-in via IntersectionObserver, then float
  // ============================================================
  const heroCard1 = document.getElementById('heroCard1') as HTMLElement;
  const heroCard2 = document.getElementById('heroCard2') as HTMLElement;
  const cardWraps = [heroCard1, heroCard2];

  const heroObserver = new IntersectionObserver((entries) => {
    if (!entries[0].isIntersecting) return;

    cardWraps.forEach((wrap, i) => {
      setTimeout(() => {
        wrap.classList.add('spring-in');

        wrap.addEventListener('animationend', () => {
          wrap.style.opacity = '1';
          wrap.classList.remove('spring-in');
          wrap.classList.add(`float-${i + 1}`);
        }, { once: true });

      }, i * 250);
    });

    heroObserver.disconnect();
  }, { threshold: 0.15 });

  const heroSection = document.getElementById('hero');
  if (heroSection) heroObserver.observe(heroSection);

  // ============================================================
  // GOLD COIN — flip on hover (CSS) + click/tap (JS)
  // ============================================================
  const coinScene  = document.getElementById('coinScene') as HTMLElement;
  const coin3d     = document.getElementById('coin3d') as HTMLElement;
  const coinHintEl = document.getElementById('coinHint') as HTMLElement;
  const chartWrap  = document.getElementById('chartWrap') as HTMLElement;
  let coinFlipped  = false;
  let chartDrawn   = false;

  if ('ontouchstart' in window || navigator.maxTouchPoints > 0) {
    coinHintEl.textContent = 'Tap to flip';
  }

  function flipCoin() {
    coinFlipped = !coinFlipped;
    coin3d.classList.toggle('flipped', coinFlipped);
    if (coinFlipped && !chartDrawn) triggerChart();
  }

  coinScene.addEventListener('click', flipCoin);
  coinScene.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); flipCoin(); }
  });

  coinScene.addEventListener('mouseenter', () => {
    if (!chartDrawn) triggerChart();
  });

  function triggerChart() {
    chartDrawn = true;
    setTimeout(() => {
      chartWrap.classList.add('visible');
      drawPieChart();
    }, 440);
  }

  // ============================================================
  // CANVAS PIE / DONUT CHART
  // ============================================================
  const PIE_DATA = [
    { label: 'Missed Deductions',    pct: 35, color: '#114b1c' },
    { label: 'Unclaimed Credits',    pct: 28, color: '#211057' },
    { label: 'IRS Penalty Interest', pct: 20, color: '#d6b12f' },
    { label: 'Filing Errors',        pct: 17, color: '#b5923b' },
  ];

  function drawPieChart() {
    const canvas   = document.getElementById('pieChart') as HTMLCanvasElement;
    const ctx      = canvas.getContext('2d')!;
    const cx       = canvas.width  / 2;
    const cy       = canvas.height / 2;
    const R        = Math.min(cx, cy) - 14;
    const HOLE     = R * 0.52;
    const START    = -Math.PI / 2;
    const DURATION = 1100;

    const legend = document.getElementById('chartLegend') as HTMLElement;
    legend.innerHTML = PIE_DATA.map(d =>
      `<div class="legend-row">
        <div class="legend-swatch" style="background:${d.color}"></div>
        ${d.label} — ${d.pct}%
      </div>`
    ).join('');

    const slices: Array<{label: string; pct: number; color: string; startA: number; endA: number}> = [];
    let a = START;
    PIE_DATA.forEach(d => {
      const sweep = (d.pct / 100) * 2 * Math.PI;
      slices.push({ ...d, startA: a, endA: a + sweep });
      a += sweep;
    });

    const t0 = performance.now();
    function frame(now: number) {
      const progress = Math.min((now - t0) / DURATION, 1);
      const ease     = 1 - Math.pow(1 - progress, 3);

      ctx.clearRect(0, 0, canvas.width, canvas.height);

      slices.forEach(s => {
        const sweep = (s.endA - s.startA) * ease;
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, R, s.startA, s.startA + sweep);
        ctx.closePath();
        ctx.fillStyle = s.color;
        ctx.fill();

        ctx.beginPath();
        ctx.arc(cx, cy, R + 0.5, s.startA, s.startA + sweep);
        ctx.strokeStyle = '#f8f4e5';
        ctx.lineWidth = 2;
        ctx.stroke();
      });

      ctx.beginPath();
      ctx.arc(cx, cy, HOLE, 0, 2 * Math.PI);
      ctx.fillStyle = '#f8f4e5';
      ctx.fill();

      if (progress >= 1) {
        ctx.textAlign    = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillStyle    = '#114b1c';
        ctx.font         = `bold 17px 'DM Serif Display', serif`;
        ctx.fillText('Annual', cx, cy - 9);
        ctx.font      = `13px 'Funnel Display', sans-serif`;
        ctx.fillStyle = '#888';
        ctx.fillText('losses', cx, cy + 10);
      }

      if (progress < 1) requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);

    const tooltip = document.getElementById('chartTooltip') as HTMLElement;
    const canvasRect = () => canvas.getBoundingClientRect();

    canvas.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = canvasRect();
      const mx   = (e.clientX - rect.left)  * (canvas.width  / rect.width);
      const my   = (e.clientY - rect.top)   * (canvas.height / rect.height);
      const dx   = mx - cx;
      const dy   = my - cy;
      const dist = Math.sqrt(dx * dx + dy * dy);

      if (dist > HOLE && dist < R) {
        let normAngle = Math.atan2(dy, dx) - START;
        if (normAngle < 0) normAngle += 2 * Math.PI;

        const hit = slices.find(s => {
          const sa = s.startA - START < 0 ? s.startA - START + 2 * Math.PI : s.startA - START;
          const ea = s.endA   - START < 0 ? s.endA   - START + 2 * Math.PI : s.endA   - START;
          return normAngle >= sa && normAngle < ea;
        });

        if (hit) {
          tooltip.textContent = `${hit.label}: ${hit.pct}%`;
          tooltip.style.opacity = '1';
          tooltip.style.left = `${e.clientX - canvasRect().left + 12}px`;
          tooltip.style.top  = `${e.clientY - canvasRect().top  - 28}px`;
          canvas.style.cursor = 'pointer';
        }
      } else {
        tooltip.style.opacity = '0';
        canvas.style.cursor   = 'default';
      }
    });

    canvas.addEventListener('mouseleave', () => {
      tooltip.style.opacity = '0';
      canvas.style.cursor   = 'default';
    });
  }

  // ============================================================
  // FAQ ACCORDION — one item open at a time
  // ============================================================
  const faqItems = document.querySelectorAll('.faq-item');

  faqItems.forEach(item => {
    const question = item.querySelector('.faq-question') as HTMLButtonElement;
    question.addEventListener('click', () => {
      const isActive = item.classList.contains('active');
      faqItems.forEach(i => {
        i.classList.remove('active');
        (i.querySelector('.faq-question') as HTMLButtonElement).setAttribute('aria-expanded', 'false');
      });
      if (!isActive) {
        item.classList.add('active');
        question.setAttribute('aria-expanded', 'true');
      }
    });
  });

  const faqObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const items = entry.target.querySelectorAll('.faq-item');
        items.forEach((item, i) => {
          setTimeout(() => item.classList.add('faq-in'), i * 80);
        });
        faqObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  const faqContainer = document.getElementById('faqContainer');
  if (faqContainer) faqObserver.observe(faqContainer);

  // ============================================================
  // CREDENTIALS CARDS — staggered fade-in
  // ============================================================
  const credGrid = document.getElementById('credentialsGrid');
  if (credGrid) {
    const credCards = credGrid.querySelectorAll('.cred-card');
    const credObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          credCards.forEach((card, i) => {
            setTimeout(() => card.classList.add('cred-visible'), i * 150);
          });
          credObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    credObserver.observe(credGrid);
  }

  // ============================================================
  // SOCIAL PROOF BAR — count-up animation
  // ============================================================
  const statsBar = document.getElementById('stats-bar');
  if (statsBar) {
    const statNums = statsBar.querySelectorAll('.stat-num');

    function animateCount(el: Element) {
      const target  = parseFloat((el as HTMLElement).dataset.target || '0');
      const suffix  = (el as HTMLElement).dataset.suffix || '';
      const prefix  = (el as HTMLElement).dataset.prefix || '';
      const isDecimal = String(target).includes('.');
      const duration = 1500;
      const start = performance.now();

      function step(now: number) {
        const progress = Math.min((now - start) / duration, 1);
        const ease = 1 - Math.pow(1 - progress, 3);
        const value = target * ease;
        el.textContent = prefix + (isDecimal ? value.toFixed(1) : Math.round(value)) + suffix;
        if (progress < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          statNums.forEach(el => animateCount(el));
          countObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });
    countObserver.observe(statsBar);
  }

  // ============================================================
  // BOOK SECTION — slide-in reveals
  // ============================================================
  const bookLeft  = document.querySelector('.book-left-reveal');
  const bookRight = document.querySelector('.book-right-reveal');
  if (bookLeft || bookRight) {
    const bookObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('book-revealed');
          bookObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    if (bookLeft)  bookObserver.observe(bookLeft);
    if (bookRight) bookObserver.observe(bookRight);
  }

  // ============================================================
  // QUOTE BANNER — fade-in on scroll
  // ============================================================
  const qbInner = document.getElementById('quoteBannerInner');
  if (qbInner) {
    const qbObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('qb-visible');
          qbObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.25 });
    qbObserver.observe(qbInner);
  }

  // ============================================================
  // SERVICES — tab switching + section scroll reveal
  // ============================================================
  const tabBtns   = document.querySelectorAll('.tab-btn');
  const tabPanels = document.querySelectorAll('.tab-panel');

  tabBtns.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
      tabPanels.forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      tabPanels[i].classList.add('active');
    });
  });

  const servicesInner = document.getElementById('servicesInner');
  if (servicesInner) {
    const svcObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('svc-visible');
          svcObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    svcObserver.observe(servicesInner);
  }

  // ============================================================
  // PAIN POINT CARDS — staggered fade-in
  // ============================================================
  const painGrid = document.getElementById('painGrid');
  if (painGrid) {
    const painCards = painGrid.querySelectorAll('.pain-card');
    const painObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          painCards.forEach((card, i) => {
            setTimeout(() => card.classList.add('pain-visible'), i * 150);
          });
          painObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    painObserver.observe(painGrid);
  }

  // ============================================================
  // LAST CHANCE SECTION — fade-in from below
  // ============================================================
  const lcInner = document.querySelector('#lastchance .lc-inner');
  if (lcInner) {
    const lcObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('lc-visible');
          lcObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    lcObserver.observe(lcInner);
  }

  // ============================================================
  // MODAL SYSTEM — job modals + blog quick-view
  // ============================================================
  const JOB_DATA: Record<string, {title: string; badge: string; items: string[]}> = {
    'tax-partner': {
      title: 'Tax Partner',
      badge: 'Remote · Commission-Based',
      items: [
        'Prepare federal and state tax returns for individuals and families',
        'Identify applicable credits and deductions',
        'Communicate clearly with clients throughout the filing process',
        'Support tax resolution cases as needed',
        'Must be IRS authorized (PTIN required) or willing to obtain certification',
        'Work fully remotely on a flexible schedule',
        'Commission-based compensation structure',
        'Limited openings per region — apply early',
      ]
    },
    'admin-assistant': {
      title: 'Administrative Assistant',
      badge: 'Remote · Part-Time',
      items: [
        'Manage client intake forms and document collection',
        'Schedule consultations and follow up with leads',
        'Handle email and phone communications professionally',
        'Maintain organized digital records',
        'Support tax partners during peak filing season',
        'Must be detail-oriented, reliable, and comfortable working remotely',
        'Part-time hours with potential to grow',
      ]
    }
  };

  const BLOG_DATA = [
    {
      title: '5 Tax Deductions Working Families Miss Every Year',
      tag: 'Tax Tips',
      emoji: '📝',
      body: [
        'Every year, millions of working families leave money on the table simply because they don\'t know what they\'re entitled to claim. The tax code is vast, and without expert guidance, it\'s easy to overlook credits and deductions that could put hundreds or even thousands of dollars back in your pocket.',
        'The Child and Dependent Care Credit alone can offset thousands of dollars in childcare expenses, yet many families fail to claim it. Similarly, the Earned Income Tax Credit is one of the most valuable credits available, but it\'s also one of the most frequently missed, particularly by self-employed parents.',
        'Home office deductions, student loan interest, educator expenses, and health savings account contributions are all commonly overlooked. If you work from home even part of the time, you may qualify for deductions that significantly reduce your taxable income.',
        'The best way to make sure you\'re claiming everything you\'re owed is to work with a tax professional who knows your situation. At Fiscus Max, we review every return for missed opportunities, and we guarantee accuracy.'
      ]
    },
    {
      title: 'What to Do When You Receive an IRS Letter',
      tag: 'IRS Help',
      emoji: '✉️',
      body: [
        'Receiving a letter from the IRS can be alarming, but most IRS correspondence is not as serious as it first appears. The key is to respond promptly and accurately. Ignoring an IRS letter almost always makes the situation worse.',
        'The first step is to read the letter carefully. Most IRS notices are about specific issues: a correction to your return, a balance due, a request for additional information, or a notice of audit. The letter will include a notice number that tells you exactly what the issue is.',
        'Do not call the number on the letter immediately. Instead, verify the notice number on the IRS website or consult a tax professional. Scam letters that mimic IRS correspondence are common, and it\'s important to confirm authenticity before taking action.',
        'If the letter is legitimate and you owe money, you have options including installment agreements, offers in compromise, and penalty abatements. At Fiscus Max, we handle IRS correspondence on your behalf so you never have to face them alone.'
      ]
    },
    {
      title: 'IRS Payment Plans Explained: What You Need to Know',
      tag: 'Resolution',
      emoji: '🗓️',
      body: [
        'If you owe taxes you can\'t pay in full, you\'re not alone, and you have more options than you might think. The IRS offers several payment arrangements designed to help taxpayers get into compliance without financial hardship.',
        'The most common option is an Installment Agreement, which lets you pay your balance over time in monthly payments. Short-term agreements can be set up for balances under $100,000. Long-term agreements are available for larger amounts and longer repayment periods.',
        'For taxpayers in significant financial hardship, the Offer in Compromise program may allow you to settle your tax debt for less than the full amount owed. The IRS evaluates your ability to pay, income, expenses, and asset equity before accepting or rejecting an offer.',
        'Currently Not Collectible status is another option. If the IRS determines you cannot pay your basic living expenses and still make payments, they may temporarily halt collection activity. At Fiscus Max, we evaluate every option to find the best resolution path for your situation.'
      ]
    }
  ];

  function openModal(id: string) {
    const overlay = document.getElementById(id) as HTMLElement;
    overlay.classList.add('modal-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal(id: string) {
    const overlay = document.getElementById(id) as HTMLElement;
    overlay.classList.remove('modal-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function openJobModal(jobId: string) {
    const job = JOB_DATA[jobId];
    (document.getElementById('jobModalBadge') as HTMLElement).textContent = job.badge;
    (document.getElementById('jobModalTitle') as HTMLElement).textContent = job.title;
    (document.getElementById('jobModalList') as HTMLElement).innerHTML = job.items.map(item => `<li>${item}</li>`).join('');
    openModal('jobModal');
  }

  const BLOG_IMAGES = [
    '/assets/images/blog_image_1.png',
    '/assets/images/blog_image_2.png',
    '/assets/images/blog_image_3.png',
  ];

  function openBlogModal(idx: number) {
    const post = BLOG_DATA[idx];
    (document.getElementById('blogModalEmoji') as HTMLElement).textContent = post.emoji;
    (document.getElementById('blogModalTag') as HTMLElement).textContent = post.tag;
    (document.getElementById('blogModalTitle') as HTMLElement).textContent = post.title;
    (document.getElementById('blogModalBody') as HTMLElement).innerHTML = post.body.map(p => `<p>${p}</p>`).join('');
    const modalImg = document.getElementById('blogModalImg') as HTMLImageElement;
    const modalEmoji = document.getElementById('blogModalEmoji') as HTMLElement;
    if (modalImg && BLOG_IMAGES[idx]) {
      modalImg.src = BLOG_IMAGES[idx];
      modalImg.alt = post.title;
      modalImg.style.display = 'block';
      if (modalEmoji) modalEmoji.style.display = 'none';
    } else {
      if (modalImg) modalImg.style.display = 'none';
      if (modalEmoji) modalEmoji.style.display = '';
    }
    openModal('blogModal');
  }

  // Expose modal functions globally for inline onclick handlers
  (window as any).openJobModal  = openJobModal;
  (window as any).openBlogModal = openBlogModal;
  (window as any).closeModal    = closeModal;

  // Close on overlay background click
  ['jobModal', 'blogModal'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('click', function(this: HTMLElement, e: Event) {
      if (e.target === this) closeModal(id);
    });
  });

  // Close on Escape key
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') {
      ['jobModal', 'blogModal'].forEach(id => closeModal(id));
    }
  });
</script>
