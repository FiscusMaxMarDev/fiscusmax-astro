    padding: 100px 24px 72px;
    text-align: center;
  }
  .post-hero-inner {
    max-width: 780px;
    margin: 0 auto;
  }
  .post-category {
    display: inline-block;
    font-family: 'Funnel Display', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #d6b12f;
    background: rgba(214, 177, 47, 0.12);
    border-radius: 100px;
    padding: 5px 14px;
    margin-bottom: 20px;
  }
  .post-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(28px, 5vw, 46px);
    font-weight: 400;
    color: #f8f4e5;
    line-height: 1.2;
    margin-bottom: 20px;
  }
  .post-meta {
    font-family: 'Funnel Display', sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: rgba(248, 244, 229, 0.5);
  }

  /* Featured image */
  .post-image-wrap {
    max-width: 860px;
    margin: -32px auto 0;
    padding: 0 24px;
  }
  .post-featured-img {
    width: 100%;
    height: 380px;
    object-fit: cover;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(6, 66, 18, 0.18);
    display: block;
  }

  /* Article */
  .post-body {
    max-width: 720px;
    margin: 56px auto 80px;
    padding: 0 24px;
  }
  .post-intro {
    font-family: 'Funnel Display', sans-serif;
    font-size: 18px;
    font-weight: 300;
