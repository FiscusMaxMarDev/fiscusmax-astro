    font-family: 'Funnel Display', sans-serif;
    font-size: 17px;
    font-weight: 300;
    color: #444;
    line-height: 1.85;
    margin-bottom: 18px;
  }
  .post-back {
    display: inline-block;
    margin-top: 48px;
    font-family: 'Funnel Display', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #064212;
    text-decoration: none;
    border-bottom: 1px solid rgba(6, 66, 18, 0.25);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }
  .post-back:hover { color: #d6b12f; border-color: #d6b12f; }

  /* CTA */
  .post-cta {
    background: linear-gradient(135deg, #064212, #0a2910);
    padding: 72px 24px;
    text-align: center;
  }
  .post-cta-inner {
    max-width: 560px;
    margin: 0 auto;
  }
  .post-cta h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 32px;
    font-weight: 400;
    color: #f8f4e5;
    margin-bottom: 14px;
  }
  .post-cta p {
    font-family: 'Funnel Display', sans-serif;
    font-size: 16px;
    font-weight: 300;
    color: rgba(248, 244, 229, 0.65);
    margin-bottom: 32px;
    line-height: 1.7;
  }
  .post-cta-btn {
    display: inline-flex;
    align-items: center;
    font-family: 'Funnel Display', sans-serif;
    font-size: 16px;
    font-weight: 400;
    padding: 15px 32px;
    background: linear-gradient(135deg, #d6b12f, #b5923b);
    color: #0a2910;
    border-radius: 8px;
