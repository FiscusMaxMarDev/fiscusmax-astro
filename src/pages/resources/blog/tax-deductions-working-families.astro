    transition: transform 0.2s, box-shadow 0.2s;
  }
  .post-cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(214, 177, 47, 0.4);
  }

  @media (max-width: 600px) {
    .post-featured-img { height: 220px; }
    .post-hero { padding: 80px 20px 56px; }
  }
</style>
